# OpenRouter API Keys
# Get your free API key from https://openrouter.ai/keys
#
# IMPORTANT: These are SERVER-SIDE only environment variables.
# Do NOT prefix them with VITE_ — that would embed them in the client bundle.
# On Vercel: add these in Project Settings → Environment Variables.
# For local dev: add to .env.local (already in .gitignore).

OPENROUTER_API_KEY_1=your_openrouter_api_key_here
OPENROUTER_API_KEY_2=your_second_key_here_optional
OPENROUTER_API_KEY_3=your_third_key_here_optional

# Optional: used as the HTTP-Referer header sent to OpenRouter
APP_URL=https://your-project.vercel.app
